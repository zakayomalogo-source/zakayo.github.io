<div id="inviteModal" style="position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);display:none;align-items:center;justify-content:center;padding:16px">
  <div style="background:var(--panel);border:1px solid rgba(34,211,160,.25);border-radius:24px;width:min(380px,100%);padding:28px 24px;box-shadow:var(--shadow);animation:cardIn .3s ease">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
      <h3 style="font-family:'Cinzel',serif;color:var(--green);font-size:18px">🔗 Alika Marafiki</h3>
      <button class="btn btn-outline btn-sm" onclick="closeInvite()">✕</button>
    </div>
    <p style="font-size:13px;color:var(--text2);margin-bottom:16px;line-height:1.6">Shiriki link hii ili marafiki wako wajiunga na Zakayo Chat. Watahitaji idhini ya admin baada ya kujisajili.</p>
    <div style="background:rgba(0,0,0,.3);border:1px solid var(--border2);border-radius:12px;padding:12px;font-size:12px;color:var(--muted);word-break:break-all;margin-bottom:12px;cursor:pointer" id="invLinkTxt" onclick="copyLink()"></div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-outline btn-sm" onclick="copyLink()" style="flex:1;padding:10px">📋 Nakili Link</button>
      <button class="wa-btn btn-sm" onclick="shareWA()" style="flex:1;padding:10px;font-size:13px;border-radius:11px">📲 WhatsApp</button>
    </div>
    <div style="margin-top:16px;padding:12px;background:rgba(34,211,160,.06);border:1px solid rgba(34,211,160,.15);border-radius:12px">
      <p style="font-size:11.5px;color:var(--muted)">💡 <strong style="color:var(--green)">Jinsi ya kutumia:</strong> Mtu anapobonyeza link, atafungua Zakayo Chat. Baada ya kujisajili, atangoja idhini yako kama admin.</p>
    </div>
  </div>
</div>

<!-- NOTIFICATIONS -->
<div class="nc" id="nc"></div>

<!-- PWA INSTALL BANNER -->
<div class="install-banner" id="installBanner">
  <span style="font-size:32px">📲</span>
  <p>Sakinisha Zakayo Chat kwenye simu yako!<span>Bonyeza hapa kuongeza kwenye skrini ya nyumbani</span></p>
  <button class="btn btn-sm" style="background:#fff;color:#7c3aed;font-weight:800;white-space:nowrap" onclick="installPWA()">Sakinisha</button>
  <button style="background:none;border:none;color:rgba(255,255,255,.6);cursor:pointer;font-size:18px;padding:4px" onclick="document.getElementById('installBanner').classList.remove('show')">✕</button>
</div>

<script>
'use strict';
/* ═══════════════════════════════════════
   ZAKAYO CHAT — ENGINE v2.1
   GitHub Pages Edition
═══════════════════════════════════════ */

const ADMIN_EMAIL = 'zakayomalogo@gmail.com';
const ADMIN_PASS  = 'Admin@Zakayo2024'; // changeable from settings later
let deferredInstall = null;

// ── STORAGE ──
const S = {
  g(k){ try{ return JSON.parse(localStorage.getItem('zc2_'+k)); }catch(e){ return null; } },
  s(k,v){ try{ localStorage.setItem('zc2_'+k, JSON.stringify(v)); }catch(e){} },
  d(k){ localStorage.removeItem('zc2_'+k); }
};

// ── STATE ──
let CU = null; // current user
let CR = null; // current room
let muted = false;
let pollTimer = null;
let lastMsgCount = {};

/* ═══════════════════════════════════════
   DB INIT
═══════════════════════════════════════ */
function initDB(){
  if(!S.g('init')){
    S.s('users',[{
      id:'admin001', name:'Zakayo Admin', email:ADMIN_EMAIL,
      pw: hp(ADMIN_PASS), ava:'👑', color:'#f0c040',
      role:'admin', ok:true, status:'online', joined: Date.now()
    }]);
    S.s('rooms',[
      {id:'r1',ico:'🌍',name:'Jumla',       desc:'Mazungumzo ya kawaida kwa wote', locked:true},
      {id:'r2',ico:'💡',name:'Mawazo',      desc:'Shiriki mawazo na mbinu mpya'},
      {id:'r3',ico:'🎵',name:'Burudani',    desc:'Muziki, michezo na starehe'},
      {id:'r4',ico:'💼',name:'Biashara',    desc:'Mazungumzo ya kazi na biashara'},
      {id:'r5',ico:'📣',name:'Matangazo',   desc:'Habari rasmi kutoka kwa admin', locked:true},
    ]);
    S.s('msgs',{});
    S.s('init',true);
  }
}

function hp(s){ let h=5381; for(let i=0;i<s.length;i++){h=((h<<5)+h)+s.charCodeAt(i);h|=0;} return (h>>>0).toString(36); }

/* ═══════════════════════════════════════
   AUTH
═══════════════════════════════════════ */
function showTab(t){
  const li = t==='login';
  document.querySelectorAll('.tab-btn').forEach((b,i)=>b.classList.toggle('active',i===(li?0:1)));
  id('fLogin').style.display = li?'block':'none';
  id('fReg').style.display   = li?'none':'block';
  id('lErr').textContent=''; id('rErr').textContent='';
}

function doLogin(){
  const email = id('lEmail').value.trim().toLowerCase();
  const pw    = id('lPass').value;
  const err   = id('lErr');
  err.textContent='';
  if(!email||!pw){ err.textContent='Jaza sehemu zote'; return; }
  const users = S.g('users')||[];
  const u = users.find(x=>x.email===email && x.pw===hp(pw));
  if(!u){ err.textContent='Barua pepe au nywila si sahihi ❌'; return; }
  u.status='online';
  S.s('users', users.map(x=>x.id===u.id?u:x));
  S.s('sess', u.id);
  CU = u;
  u.ok ? enterApp() : showWait();
}

function doRegister(){
  const name  = id('rName').value.trim();
  const email = id('rEmail').value.trim().toLowerCase();
  const pw    = id('rPass').value;
  const pw2   = id('rPass2').value;
  const err   = id('rErr');
  err.textContent='';
  if(!name||!email||!pw||!pw2){ err.textContent='Jaza sehemu zote ✋'; return; }
  if(pw!==pw2){ err.textContent='Nywila hazifanani ❌'; return; }
  if(pw.length<6){ err.textContent='Nywila angalau herufi 6 🔒'; return; }
  if(!/\S+@\S+\.\S+/.test(email)){ err.textContent='Barua pepe si sahihi ❌'; return; }
  const users = S.g('users')||[];
  if(users.find(x=>x.email===email)){ err.textContent='Barua pepe tayari ipo 📧'; return; }
  const colors = ['#a855f7','#60a5fa','#22d3a0','#f87171','#fb923c','#facc15','#34d399','#e879f9'];
  const avas   = ['😊','🌟','🎯','🔥','💎','🦋','🌺','⚡','🎪','🌈'];
  const isAdmin = email===ADMIN_EMAIL;
  const nu = {
    id: 'u'+Date.now(),
    name, email, pw: hp(pw),
    ava: avas[Math.floor(Math.random()*avas.length)],
    color: colors[Math.floor(Math.random()*colors.length)],
    role: isAdmin?'admin':'member',
    ok: isAdmin, status:'offline',
    joined: Date.now()
  };
  users.push(nu);
  S.s('users',users);
  S.s('sess',nu.id);
  CU = nu;
  if(!isAdmin) postSysMsg('r5', `📬 Mtumiaji mpya anataka kujiunga: **${nu.name}** (${nu.email})`);
  nu.ok ? enterApp() : showWait();
}

function showWait(){
  screens('waitScreen');
}

function doLogout(){
  if(CU){ const us=S.g('users')||[]; S.s('users',us.map(u=>u.id===CU.id?{...u,status:'offline'}:u)); }
  S.d('sess'); CU=null; CR=null;
  clearInterval(pollTimer);
  id('lEmail').value=''; id('lPass').value=''; id('lErr').textContent='';
  screens('authScreen');
}

/* ═══════════════════════════════════════
   ENTER APP
═══════════════════════════════════════ */
function enterApp(){
  screens('appScreen');
  renderSB();
  id('adminFab').style.display = CU.role==='admin' ? 'flex' : 'none';
  clearInterval(pollTimer);
  pollTimer = setInterval(poll,2000);
  notify('👋','Karibu!',`Habari ${CU.name}! Umeingia vizuri.`,'green');
  askNotifPerm();
}

function renderSB(){
  const av = id('myAva');
  av.textContent = CU.ava;
  av.style.background = CU.color;
  id('myName').textContent = CU.name;
  const roleEl = id('myRole');
  roleEl.textContent = CU.role==='admin'?'👑 Admin':'Mwanachama';
  roleEl.className = 'uc-role '+(CU.role==='admin'?'role-admin':'role-member');
  renderRooms();
}

/* ═══════════════════════════════════════
   ROOMS
═══════════════════════════════════════ */
function renderRooms(filter=''){
  const rooms = (S.g('rooms')||[]).filter(r=>!filter||r.name.toLowerCase().includes(filter.toLowerCase()));
  const msgs  = S.g('msgs')||{};
  id('roomList').innerHTML = rooms.map(r=>{
    const rm  = msgs[r.id]||[];
    const last = rm.filter(m=>!m.sys).slice(-1)[0];
    const prev = last ? (last.txt.replace(/\*\*/g,'').substring(0,30)+(last.txt.length>30?'…':'')) : 'Bado hakuna ujumbe';
    const unread = rm.filter(m=>!m.read && m.uid!==CU.id).length;
    const isAct = CR && CR.id===r.id;
    return `<div class="ri${isAct?' active':''}" onclick="openRoom('${r.id}')">
      <div class="ri-icon">${r.ico}</div>
      <div class="ri-info">
        <div class="ri-name">${r.name}</div>
        <div class="ri-prev">${prev}</div>
      </div>
      ${unread>0?`<div class="unread">${unread}</div>`:''}
    </div>`;
  }).join('');
}

function filterRooms(v){ renderRooms(v); }

/* ═══════════════════════════════════════
   OPEN ROOM & MESSAGES
═══════════════════════════════════════ */
function openRoom(rid){
  const rooms = S.g('rooms')||[];
  CR = rooms.find(r=>r.id===rid);
  if(!CR) return;
  id('sidebar').classList.remove('open');
  id('welcome').style.display='none';
  id('msgs').style.display='flex';
  id('inputArea').style.display='block';
  id('chIcon').textContent = CR.ico;
  id('chName').textContent = CR.name;
  const users = S.g('users')||[];
  id('chSub').textContent = `${users.filter(u=>u.ok).length} wanachama · ${CR.desc}`;
  markRead(rid);
  renderMsgs();
  renderRooms();
}

function markRead(rid){
  const msgs = S.g('msgs')||{};
  if(msgs[rid]) msgs[rid]=msgs[rid].map(m=>m.uid===CU.id?m:{...m,read:true});
  S.s('msgs',msgs);
}

function renderMsgs(){
  if(!CR) return;
  const msgs  = S.g('msgs')||{};
  const rm    = msgs[CR.id]||[];
  const users = S.g('users')||[];
  const el    = id('msgs');
  const atBot = el.scrollHeight-el.scrollTop-el.clientHeight < 120;

  let html='', lastDay='';
  rm.forEach(m=>{
    const d   = new Date(m.ts);
    const day = d.toLocaleDateString('sw-TZ',{weekday:'long',day:'numeric',month:'long'});
    if(day!==lastDay){ html+=`<div class="day-div"><span>${day}</span></div>`; lastDay=day; }
    if(m.sys){ html+=`<div class="mrow sys"><div class="sys-bubble">📣 ${fmt(m.txt)}</div></div>`; return; }
    const sender = users.find(u=>u.id===m.uid)||{name:'?',color:'#888',ava:'?'};
    const isMe   = m.uid===CU.id;
    const time   = d.toLocaleTimeString('sw-TZ',{hour:'2-digit',minute:'2-digit'});
    const reacts = (m.rcts||[]).map(r=>`<div class="react" onclick="addReact('${m.id}','${r.e}')">${r.e}<span class="react-count">${r.n}</span></div>`).join('');
    html+=`<div class="mrow ${isMe?'me':'them'}">
      ${!isMe?`<div class="mava" style="background:${sender.color};font-size:${isEmoji(sender.ava)?'14':'11'}px">${sender.ava}</div>`:''}
      <div class="bubble-wrap">
        ${!isMe?`<div class="sname" style="color:${sender.color}">${sender.name}</div>`:''}
        <div class="bubble">${fmt(m.txt)}
          <div class="bm">
            <span class="btime">${time}</span>
            ${isMe?`<span class="bcheck${m.read?' seen':''}">✓✓</span>`:''}
          </div>
        </div>
        ${reacts||m.rcts&&m.rcts.length?`<div class="react-bar">${reacts}<button class="react-add" onclick="quickReact('${m.id}')">+😊</button></div>`:`<button class="react-add" onclick="quickReact('${m.id}')">+ Jibu</button>`}
      </div>
      ${isMe?`<div class="mava" style="background:${CU.color};font-size:${isEmoji(CU.ava)?'14':'11'}px">${CU.ava}</div>`:''}
    </div>`;
  });

  if(!rm.length) html='<div style="text-align:center;color:var(--muted);margin:auto;font-size:14px;padding:40px">Hakuna ujumbe bado.<br>Anza mazungumzo! 🌟</div>';
  el.innerHTML=html;
  if(atBot||rm.length<=3) el.scrollTop=el.scrollHeight;
}

function fmt(t){
  return String(t)
    .replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.*?)\*/g,'<em>$1</em>')
    .replace(/(https?:\/\/[^\s<]+)/g,'<a href="$1" target="_blank" rel="noopener" style="color:var(--blue);word-break:break-all">$1</a>')
    .replace(/\n/g,'<br>');
}

function isEmoji(s){ return /\p{Emoji}/u.test(s); }

/* ═══════════════════════════════════════
   SEND MESSAGE
═══════════════════════════════════════ */
function sendMsg(){
  const inp = id('mi');
  const txt = inp.value.trim();
  if(!txt||!CR) return;
  const msgs = S.g('msgs')||{};
  if(!msgs[CR.id]) msgs[CR.id]=[];
  msgs[CR.id].push({id:'m'+Date.now()+Math.random().toString(36).slice(2,6), uid:CU.id, txt, ts:Date.now(), read:false, rcts:[]});
  S.s('msgs',msgs);
  inp.value=''; inp.style.height='auto';
  id('ep').classList.remove('open');
  renderMsgs(); renderRooms();
}

function handleKey(e){ if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();} }
function autoR(t){ t.style.height='auto'; t.style.height=Math.min(t.scrollHeight,120)+'px'; }

/* ═══════════════════════════════════════
   REACTIONS
═══════════════════════════════════════ */
function addReact(mid,emoji){
  const msgs=S.g('msgs')||{}, rm=msgs[CR.id]||[];
  const m=rm.find(x=>x.id===mid); if(!m) return;
  if(!m.rcts) m.rcts=[];
  const ex=m.rcts.find(r=>r.e===emoji);
  if(ex) ex.n=(ex.n||1)+1; else m.rcts.push({e:emoji,n:1});
  S.s('msgs',msgs); renderMsgs();
}

function quickReact(mid){
  const opts=['❤️','👍','😂','🔥','😮','👏','✅','🙏'];
  addReact(mid, opts[Math.floor(Math.random()*opts.length)]);
}

/* ═══════════════════════════════════════
   EMOJI PICKER
═══════════════════════════════════════ */
const EMOJIS='😀😁😂🤣😊😍🥰😎🤩😋😏🤗😔😢😭😤🥳🎉🔥❤️💯✨💎🌟👑🙏💪👍🤝🌍🎵🎶🚀💡🌺🦋💬📱💻🎁🍕☕🎯💰🏆🌈⚡🎪🎭🦁🐯🌙⭐🎊🥂🍾🎸🎹'.split('');
function buildEP(){
  id('ep').innerHTML=EMOJIS.map(e=>`<button class="ep-btn" onclick="insertE('${e}')">${e}</button>`).join('');
}
function toggleEmoji(){ id('ep').classList.toggle('open'); }
function insertE(e){ const i=id('mi'); i.value+=e; i.focus(); id('ep').classList.remove('open'); }
document.addEventListener('click',e=>{ if(!e.target.closest('.ia-small')&&!e.target.closest('.ep')) id('ep').classList.remove('open'); });

/* ═══════════════════════════════════════
   POLL (simulate live updates)
═══════════════════════════════════════ */
function poll(){
  if(CR) renderMsgs();
  // Check for new messages in other rooms & notify
  const msgs=S.g('msgs')||{};
  Object.keys(msgs).forEach(rid=>{
    if(CR&&rid===CR.id) return;
    const rm=msgs[rid]||[];
    const prev=lastMsgCount[rid]||0;
    const news=rm.filter(m=>!m.read&&m.uid!==CU.id);
    if(news.length>prev){
      const m=news[news.length-1];
      const rooms=S.g('rooms')||[];
      const room=rooms.find(r=>r.id===rid);
      const users=S.g('users')||[];
      const sender=users.find(u=>u.id===m.uid);
      if(room&&sender&&!m.sys){
        notify('💬',room.name,`${sender.name}: ${m.txt.substring(0,40)}${m.txt.length>40?'…':''}`);
      }
    }
    lastMsgCount[rid]=news.length;
  });
  renderRooms();
}

/* ═══════════════════════════════════════
   NOTIFICATIONS
═══════════════════════════════════════ */
function notify(icon,title,text,type=''){
  if(muted) return;
  const c=id('nc'), n=document.createElement('div');
  n.className='notif'+(type?' n-'+type:'');
  n.innerHTML=`<div class="n-icon">${icon}</div>
    <div class="n-body"><div class="n-title">${title}</div><div class="n-text">${text}</div></div>
    <button class="n-close" onclick="closeN(this.parentElement)">✕</button>`;
  c.appendChild(n);
  if('Notification' in window && Notification.permission==='granted'){
    new Notification('Zakayo Chat — '+title,{body:text,icon:'data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><rect width="100" height="100" rx="20" fill="%237c3aed"/><text y=".9em" font-size="75" x="12">💬</text></svg>'});
  }
  setTimeout(()=>closeN(n),5000);
}
function closeN(n){ if(!n||!n.parentElement) return; n.classList.add('out'); setTimeout(()=>n.remove(),280); }
function toggleMute(){ muted=!muted; id('muteIco').textContent=muted?'🔕':'🔔'; notify(muted?'🔕':'🔔','Arifa',muted?'Arifa zimezimwa':'Arifa zimewashwa'); }
function askNotifPerm(){ if('Notification' in window && Notification.permission==='default') Notification.requestPermission(); }

/* ═══════════════════════════════════════
   ADMIN PANEL
═══════════════════════════════════════ */
function openAdmin(){
  if(CU.role!=='admin'){ notify('🚫','Ruhusa Imekatazwa','Huna mamlaka ya admin','red'); return; }
  id('adminPanel').classList.add('open');
  aTab('overview');
}
function closeAdmin(){ id('adminPanel').classList.remove('open'); }

function aTab(t){
  const tabs=['overview','users','pending','rooms','broadcast','settings'];
  document.querySelectorAll('.atab').forEach((el,i)=>el.classList.toggle('active',tabs[i]===t));
  document.querySelectorAll('.asec').forEach(s=>s.classList.remove('active'));
  id('as-'+t).classList.add('active');
  if(t==='overview')  renderStats();
  if(t==='users')     renderUsers();
  if(t==='pending')   renderPending();
  if(t==='rooms')     renderRoomMgr();
}

function renderStats(){
  const users=S.g('users')||[], msgs=S.g('msgs')||{}, rooms=S.g('rooms')||[];
  const total=Object.values(msgs).reduce((s,a)=>s+a.length,0);
  const online=users.filter(u=>u.status==='online').length;
  id('statGrid').innerHTML=[
    ['var(--gold)',  users.filter(u=>u.ok).length,    'Wanachama Waliokubaliwa'],
    ['var(--gold2)', users.filter(u=>!u.ok).length,   'Wanaosubiri Idhini'],
    ['var(--green)', total,                            'Jumla ya Ujumbe Wote'],
    ['var(--accent)',rooms.length,                     'Vyumba vya Gumzo'],
    ['var(--blue)',  online,                           'Watandaoni Sasa Hivi'],
    ['var(--orange)',users.length,                     'Watumiaji Wote'],
  ].map(([c,n,l])=>`<div class="sc"><div class="sc-num" style="color:${c}">${n}</div><div class="sc-lbl">${l}</div></div>`).join('');
}

function renderUsers(){
  const users=S.g('users')||[];
  id('userCount').textContent=`Jumla: ${users.length}`;
  document.querySelector('#utbl tbody').innerHTML=users.map(u=>`
    <tr>
      <td><div style="display:flex;gap:8px;align-items:center">
        <div style="width:28px;height:28px;border-radius:50%;background:${u.color};display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;flex-shrink:0">${u.ava}</div>
        <span style="font-weight:600">${u.name}</span></div></td>
      <td style="color:var(--muted)">${u.email}</td>
      <td><span class="spill ${u.ok?'sp-g':'sp-y'}">${u.ok?'✓ Amekubaliwa':'⏳ Inasubiri'}</span></td>
      <td><span class="spill ${u.role==='admin'?'sp-y':'sp-g'}">${u.role==='admin'?'👑 Admin':'👤 Mwanachama'}</span></td>
      <td>
        ${u.id!=='admin001'?`
          ${!u.ok?`<button class="btn btn-sm btn-primary" onclick="approveU('${u.id}')" style="margin-right:4px">✓</button>`:''}
          <button class="btn btn-sm btn-danger" onclick="removeU('${u.id}')">✕</button>
        `:'<span style="color:var(--gold);font-size:12px">Mkuu</span>'}
      </td>
    </tr>`).join('');
}

function renderPending(){
  const pending=(S.g('users')||[]).filter(u=>!u.ok);
  const el=id('pendingList');
  if(!pending.length){ el.innerHTML='<div style="text-align:center;padding:40px;color:var(--muted)">🎉 Hakuna wanasubiri kwa sasa!</div>'; return; }
  el.innerHTML=pending.map(u=>`
    <div class="pcard">
      <div style="width:44px;height:44px;border-radius:50%;background:${u.color};display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">${u.ava}</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:13.5px">${u.name}</div>
        <div style="font-size:11.5px;color:var(--muted)">${u.email}</div>
        <div style="font-size:10.5px;color:var(--muted);margin-top:2px">Alijisajili: ${new Date(u.joined).toLocaleDateString('sw-TZ')}</div>
      </div>
      <button class="btn btn-sm btn-primary" onclick="approveU('${u.id}');renderPending()" style="margin-right:4px">✓ Kubali</button>
      <button class="btn btn-sm btn-danger" onclick="removeU('${u.id}');renderPending()">✕ Kataa</button>
    </div>`).join('');
}

function approveU(uid){
  const users=S.g('users')||[], u=users.find(x=>x.id===uid);
  S.s('users',users.map(x=>x.id===uid?{...x,ok:true}:x));
  if(u){ postSysMsg('r1',`🎉 Karibu! **${u.name}** amejiunga na Zakayo Chat!`); }
  notify('✅','Imekubaliwa',`${u?u.name:'Mtumiaji'} amepewa ruhusa`,'green');
  renderUsers(); renderStats();
}

function removeU(uid){
  if(!confirm('Una uhakika wa kumfuta mtumiaji huyu?')) return;
  S.s('users',(S.g('users')||[]).filter(u=>u.id!==uid));
  notify('🗑️','Mtumiaji Amefutwa','','warn');
  renderUsers(); renderStats();
}

function renderRoomMgr(){
  const rooms=S.g('rooms')||[];
  id('roomMgr').innerHTML=rooms.map(r=>`
    <div class="rm-row">
      <div style="font-size:24px">${r.ico}</div>
      <div style="flex:1">
        <div style="font-weight:700;font-size:13.5px">${r.name}</div>
        <div style="font-size:11.5px;color:var(--muted);margin-top:2px">${r.desc}</div>
      </div>
      ${!r.locked?`<button class="btn btn-sm btn-danger" onclick="delRoom('${r.id}')">🗑️ Futa</button>`:'<span style="font-size:11px;color:var(--muted);padding:4px 8px;background:var(--glass);border-radius:8px">Imehifadhiwa</span>'}
    </div>`).join('');
}

function addRoom(){
  const ico=id('nrEmoji').value.trim()||'💬', name=id('nrName').value.trim(), desc=id('nrDesc').value.trim();
  if(!name){ notify('⚠️','Hitilafu','Weka jina la chumba','warn'); return; }
  const rooms=S.g('rooms')||[];
  rooms.push({id:'r'+Date.now(),ico,name,desc:desc||'Chumba kipya cha mazungumzo'});
  S.s('rooms',rooms);
  id('nrEmoji').value=''; id('nrName').value=''; id('nrDesc').value='';
  renderRoomMgr(); renderRooms();
  notify('✅','Chumba Kimeongezwa',`${ico} ${name}`,'green');
}

function delRoom(rid){
  if(!confirm('Futa chumba hiki na ujumbe wake wote?')) return;
  S.s('rooms',(S.g('rooms')||[]).filter(r=>r.id!==rid));
  const msgs=S.g('msgs')||{}; delete msgs[rid]; S.s('msgs',msgs);
  if(CR&&CR.id===rid){ CR=null; id('msgs').style.display='none'; id('inputArea').style.display='none'; id('welcome').style.display='flex'; }
  renderRoomMgr(); renderRooms();
}

function doBroadcast(){
  const txt=id('bcastMsg').value.trim();
  if(!txt){ notify('⚠️','Hakuna ujumbe','Andika ujumbe wa tangazo','warn'); return; }
  const msgs=S.g('msgs')||{}, rooms=S.g('rooms')||[];
  rooms.forEach(r=>{ if(!msgs[r.id]) msgs[r.id]=[]; msgs[r.id].push({id:'m'+Date.now()+r.id,uid:'admin001',txt:`📢 TANGAZO: ${txt}`,ts:Date.now(),read:false,rcts:[],sys:true}); });
  S.s('msgs',msgs);
  id('bcastMsg').value='';
  notify('📢','Tangazo Limetumwa','Ujumbe umewafikia wote!','green');
  if(CR) renderMsgs();
}

function clearAllMsgs(){ if(!confirm('Futa ujumbe WOTE wa vyumba vyote?')) return; S.s('msgs',{}); if(CR) renderMsgs(); notify('🗑️','Imefutwa','Ujumbe wote umefutwa','warn'); }
function exportData(){
  const data={users:S.g('users'),rooms:S.g('rooms'),msgs:S.g('msgs'),exported:new Date().toISOString()};
  const b=new Blob([JSON.stringify(data,null,2)],{type:'application/json'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download='ZakayoChat_backup.json'; a.click();
}
function fullReset(){ if(!confirm('RESET KAMILI? Kila kitu kitafutwa!')) return; localStorage.clear(); location.reload(); }

/* ═══════════════════════════════════════
   PROFILE
═══════════════════════════════════════ */
function openProfile(){
  id('profContent').innerHTML=`
    <div style="display:flex;justify-content:flex-end;margin-bottom:-8px"><button class="btn btn-outline btn-sm" onclick="document.getElementById('profileModal').classList.remove('open')">✕</button></div>
    <div class="prof-top">
      <div class="prof-ava" style="background:${CU.color}">${CU.ava}</div>
      <div class="prof-name">${CU.name}</div>
      <div class="prof-email">${CU.email}</div>
      <div class="prof-badge">${CU.role==='admin'?'👑 Admin':'👤 Mwanachama'}</div>
    </div>
    <div style="margin-bottom:12px">
      <label style="font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;display:block;margin-bottom:5px">Badilisha Nywila</label>
      <div style="display:flex;gap:8px">
        <input type="password" id="npw" placeholder="Nywila mpya (min. 6)" style="flex:1;padding:9px 12px;background:rgba(0,0,0,.3);border:1px solid var(--border2);border-radius:10px;color:var(--text);font-size:13px;font-family:'DM Sans',sans-serif;outline:none">
        <button class="btn btn-primary btn-sm" onclick="changePw()">Hifadhi</button>
      </div>
    </div>
    <div class="inv-box">
      <h4>🔗 Alika Marafiki</h4>
      <div class="inv-link" id="iLink" onclick="copyLink()" title="Bonyeza kunakili">${location.href}</div>
      <div style="display:flex;gap:8px">
        <button class="btn btn-outline btn-sm" onclick="copyLink()" style="flex:1;padding:9px">📋 Nakili</button>
        <button class="wa-btn" onclick="shareWA()" style="flex:1">📲 WhatsApp</button>
      </div>
    </div>`;
  id('profileModal').classList.add('open');
}

function changePw(){
  const pw=id('npw')?.value; if(!pw||pw.length<6){ notify('⚠️','Nywila fupi','Angalau herufi 6','warn'); return; }
  const users=S.g('users')||[];
  S.s('users',users.map(u=>u.id===CU.id?{...u,pw:hp(pw)}:u));
  CU={...CU,pw:hp(pw)}; id('npw').value='';
  notify('✅','Imehifadhiwa','Nywila imebadilishwa','green');
}

/* ═══════════════════════════════════════
   INVITE
═══════════════════════════════════════ */
function openInviteModal(){
  id('invLinkTxt').textContent = location.href;
  id('inviteModal').style.display='flex';
}
function closeInvite(){ id('inviteModal').style.display='none'; }

function copyLink(){
  navigator.clipboard.writeText(location.href).then(()=>notify('📋','Imenakiliwa','Link imenakiliwa kwenye ubao wa kunakili','green')).catch(()=>{
    const t=document.createElement('textarea'); t.value=location.href; document.body.appendChild(t); t.select(); document.execCommand('copy'); t.remove();
    notify('📋','Imenakiliwa','Link imenakiliwa','green');
  });
}

function shareWA(){
  const msg=encodeURIComponent(`🌟 Jiunge na *Zakayo Chat*!\n\nApp ya mazungumzo ya kweli, salama na ya haraka kwa marafiki na wadau.\n\n💬 Bonyeza hapa kujisajili:\n${location.href}\n\n_Zakayo Chat — Mazungumzo Ya Kweli_ ✨`);
  window.open('https://wa.me/?text='+msg,'_blank');
}

/* ═══════════════════════════════════════
   MISC
═══════════════════════════════════════ */
function postSysMsg(rid,txt){
  const msgs=S.g('msgs')||{};
  if(!msgs[rid]) msgs[rid]=[];
  msgs[rid].push({id:'m'+Date.now(),uid:'admin001',txt,ts:Date.now(),read:false,rcts:[],sys:true});
  S.s('msgs',msgs);
}

function simulateAttach(){ notify('📎','Faili','Kipengele cha faili kitapatikana hivi karibuni 🚧','warn'); }

function toggleSearch(){ id('sidebar').classList.toggle('open'); document.querySelector('.sb-search input').focus(); }
function closeSidebar(){ id('sidebar').classList.remove('open'); }

function downloadApp(){
  const html=document.documentElement.outerHTML;
  const b=new Blob([html],{type:'text/html'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(b); a.download='ZakayoChat.html'; a.click();
  notify('⬇️','Inapakuliwa','ZakayoChat.html imehifadhiwa kwenye simu/kompyuta yako','green');
}

function id(x){ return document.getElementById(x); }
function screens(s){ document.querySelectorAll('.screen').forEach(el=>{ el.classList.remove('active'); el.style.display=''; }); const el=id(s); el.classList.add('active'); if(s==='appScreen') el.style.display='flex'; }

/* ── SWIPE GESTURES (mobile) ── */
let tx=0;
document.addEventListener('touchstart',e=>tx=e.touches[0].clientX,{passive:true});
document.addEventListener('touchend',e=>{
  const dx=e.changedTouches[0].clientX-tx;
  if(dx>65&&tx<45) id('sidebar').classList.add('open');
  if(dx<-65)       id('sidebar').classList.remove('open');
},{passive:true});

/* ── PWA INSTALL ── */
window.addEventListener('beforeinstallprompt',e=>{
  e.preventDefault(); deferredInstall=e;
  setTimeout(()=>id('installBanner').classList.add('show'),3000);
});
function installPWA(){
  id('installBanner').classList.remove('show');
  if(deferredInstall){ deferredInstall.prompt(); deferredInstall.userChoice.then(r=>{ if(r.outcome==='accepted') notify('✅','Imewekwa','Zakayo Chat imesakinishwa kwenye simu yako!','green'); deferredInstall=null; }); }
}
window.addEventListener('appinstalled',()=>notify('✅','Imesakinishwa','Zakayo Chat ipo kwenye skrini yako ya nyumbani! 🎉','green'));

/* ── SERVICE WORKER ── */
if('serviceWorker' in navigator){ window.addEventListener('load',()=>navigator.serviceWorker.register('sw.js').catch(()=>{})); }

/* ── BOOT ── */
window.addEventListener('load',()=>{
  initDB(); buildEP();
  const sid=S.g('sess');
  if(sid){
    const u=(S.g('users')||[]).find(x=>x.id===sid);
    if(u){ CU=u; u.ok?enterApp():showWait(); return; }
  }
  screens('authScreen');
});
</script>
</body>
</html>
