══════════════════════════════ -->
<div class="screen active" id="authScreen">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="logo">
        <div class="logo-ring">💬</div>
        <h1>Zakayo Chat</h1>
        <p>Mazungumzo Ya Kweli · Salama · Ya Haraka</p>
      </div>
      <div class="tabs">
        <button class="tab-btn active" onclick="showTab('login')">🔑 Ingia</button>
        <button class="tab-btn" onclick="showTab('register')">✨ Jisajili</button>
      </div>

      <!-- LOGIN -->
      <div id="fLogin">
        <div class="form-group">
          <label>Barua Pepe</label>
          <div class="input-icon-wrap"><span class="fi">📧</span><input type="email" id="lEmail" placeholder="barua@pepe.com" autocomplete="email"></div>
        </div>
        <div class="form-group">
          <label>Nywila</label>
          <div class="input-icon-wrap"><span class="fi">🔒</span><input type="password" id="lPass" placeholder="Nywila yako" autocomplete="current-password" onkeydown="if(event.key==='Enter')doLogin()"></div>
        </div>
        <button class="btn btn-primary" onclick="doLogin()">Ingia Sasa →</button>
        <div class="auth-err" id="lErr"></div>
      </div>

      <!-- REGISTER -->
      <div id="fReg" style="display:none">
        <div class="form-group">
          <label>Jina Kamili</label>
          <div class="input-icon-wrap"><span class="fi">👤</span><input type="text" id="rName" placeholder="Jina lako kamili"></div>
        </div>
        <div class="form-group">
          <label>Barua Pepe</label>
          <div class="input-icon-wrap"><span class="fi">📧</span><input type="email" id="rEmail" placeholder="barua@pepe.com"></div>
        </div>
        <div class="form-group">
          <label>Nywila</label>
          <div class="input-icon-wrap"><span class="fi">🔒</span><input type="password" id="rPass" placeholder="Angalau herufi 6"></div>
        </div>
        <div class="form-group">
          <label>Thibitisha Nywila</label>
          <div class="input-icon-wrap"><span class="fi">✅</span><input type="password" id="rPass2" placeholder="Rudia nywila" onkeydown="if(event.key==='Enter')doRegister()"></div>
        </div>
        <button class="btn btn-primary" onclick="doRegister()">Jisajili Sasa →</button>
        <div class="auth-err" id="rErr"></div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════
     WAITING SCREEN
══════════════════════════════ -->
<div class="screen" id="waitScreen">
  <div class="wait-card">
    <span class="wait-anim">⏳</span>
    <h2>Inasubiri Idhini</h2>
    <p>Asante kwa kujisajili! Akaunti yako ipo katika mstari wa kusubiri. Admin <strong>zakayomalogo@gmail.com</strong> atakupitishia hivi karibuni.</p>
    <div class="status-pill"><div class="pulse-dot"></div> Inasubiri ukaguzi wa admin</div>
    <br><br>
    <button class="btn btn-outline btn-sm" onclick="doLogout()" style="width:auto;padding:9px 24px">← Rudi kuingia</button>
  </div>
</div>

<!-- ══════════════════════════════
     MAIN APP
══════════════════════════════ -->
<div class="screen" id="appScreen">

  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <div class="sb-header">
      <div class="sb-brand">
        <div class="sb-logo">💬</div>
        <div>
          <div class="sb-title">Zakayo Chat</div>
          <div class="sb-version">v2.1 · GitHub Live</div>
        </div>
      </div>
      <div class="user-card">
        <div class="ava" id="myAva" style="background:#a855f7">Z<div class="sdot"></div></div>
        <div style="flex:1;min-width:0">
          <div class="uc-name" id="myName">—</div>
          <div style="font-size:10px;color:var(--green)">● Mtandaoni</div>
        </div>
        <div class="uc-role role-member" id="myRole">Mwanachama</div>
      </div>
    </div>

    <div class="sb-search">
      <span class="si">🔍</span>
      <input type="text" placeholder="Tafuta vyumba..." oninput="filterRooms(this.value)">
    </div>

    <div class="sec-label">Vyumba vya Gumzo</div>
    <div class="room-list" id="roomList"></div>

    <div class="sb-footer">
      <div class="fb" onclick="openProfile()" title="Profaili">👤<span class="fb-tip">Profaili</span></div>
      <div class="fb" onclick="openInviteModal()" title="Alika">🔗<span class="fb-tip">Alika</span></div>
      <div class="fb fb-admin" id="adminFab" onclick="openAdmin()" style="display:none" title="Admin">⚙️<span class="fb-tip">Admin</span></div>
      <div class="fb fb-dl" onclick="downloadApp()" title="Pakua">⬇️<span class="fb-tip">Pakua</span></div>
      <div class="fb" onclick="doLogout()" title="Toka">🚪<span class="fb-tip">Toka</span></div>
    </div>
  </div>

  <!-- CHAT AREA -->
  <div class="chat-area">
    <div class="chat-header">
      <button class="back-btn" onclick="closeSidebar()">←</button>
      <div class="ch-icon" id="chIcon">💬</div>
      <div class="ch-info">
        <div class="ch-name" id="chName">Zakayo Chat</div>
        <div class="ch-sub" id="chSub">Chagua chumba kushoto</div>
      </div>
      <div class="ch-actions">
        <div class="ia" onclick="toggleSearch()" title="Tafuta">🔍</div>
        <div class="ia" id="muteIco" onclick="toggleMute()" title="Kimya/Arifa">🔔</div>
      </div>
    </div>

    <div class="welcome" id="welcome">
      <div class="wi">✨</div>
      <h3>Karibu Zakayo Chat!</h3>
      <p>Chagua chumba upande wa kushoto ili kuanza mazungumzo yako na marafiki.</p>
    </div>

    <div class="msgs" id="msgs" style="display:none"></div>

    <div class="input-area" id="inputArea" style="display:none">
      <div style="position:relative">
        <div class="ep" id="ep"></div>
        <div class="ir">
          <div class="ia-small" onclick="simulateAttach()" title="Faili">📎</div>
          <div class="ia-small" onclick="toggleEmoji()" title="Emoji">😊</div>
          <div class="input-wrap">
            <textarea class="mi" id="mi" rows="1" placeholder="Andika ujumbe..." oninput="autoR(this)" onkeydown="handleKey(event)"></textarea>
          </div>
          <button class="send-btn" onclick="sendMsg()">➤</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════
     ADMIN PANEL
══════════════════════════════ -->
<div id="adminPanel">
  <div class="admin-card">
    <div class="admin-top">
      <h2>⚙️ Dashibodi ya Admin</h2>
      <button class="btn btn-outline btn-sm" onclick="closeAdmin()">✕ Funga</button>
    </div>
    <div class="admin-tabs" id="adminTabs">
      <div class="atab active" onclick="aTab('overview')">📊 Muhtasari</div>
      <div class="atab" onclick="aTab('users')">👥 Watumiaji</div>
      <div class="atab" onclick="aTab('pending')">⏳ Wanaosubiri</div>
      <div class="atab" onclick="aTab('rooms')">💬 Vyumba</div>
      <div class="atab" onclick="aTab('broadcast')">📢 Tangazo</div>
      <div class="atab" onclick="aTab('settings')">🛠️ Mipangilio</div>
    </div>
    <div class="admin-body">

      <!-- OVERVIEW -->
      <div class="asec active" id="as-overview">
        <div class="stat-grid" id="statGrid"></div>
        <div style="background:var(--glass);border:1px solid var(--border2);border-radius:12px;padding:14px;font-size:12.5px;color:var(--muted)">
          <strong style="color:var(--gold)">Zakayo Chat</strong> v2.1 · Admin: zakayomalogo@gmail.com<br>
          Data imehifadhiwa kwenye kifaa kwa njia salama · GitHub Pages Live
        </div>
      </div>

      <!-- USERS -->
      <div class="asec" id="as-users">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px">
          <h3 style="font-size:14px;font-weight:800">Watumiaji Wote</h3>
          <span style="font-size:12px;color:var(--muted)" id="userCount"></span>
        </div>
        <div style="overflow-x:auto">
          <table class="utbl" id="utbl"><tbody></tbody></table>
        </div>
      </div>

      <!-- PENDING -->
      <div class="asec" id="as-pending">
        <h3 style="font-size:14px;font-weight:800;margin-bottom:14px;color:var(--gold)">⏳ Wanaosubiri Idhini</h3>
        <div id="pendingList"></div>
      </div>

      <!-- ROOMS -->
      <div class="asec" id="as-rooms">
        <h3 style="font-size:14px;font-weight:800;margin-bottom:14px">Simamia Vyumba</h3>
        <div id="roomMgr"></div>
        <div class="add-room-box">
          <h4>+ Ongeza Chumba Kipya</h4>
          <div class="af">
            <input type="text" id="nrEmoji" placeholder="Emoji" style="max-width:72px">
            <input type="text" id="nrName" placeholder="Jina la chumba">
            <input type="text" id="nrDesc" placeholder="Maelezo">
            <button class="btn btn-gold btn-sm" onclick="addRoom()">+ Ongeza</button>
          </div>
        </div>
      </div>

      <!-- BROADCAST -->
      <div class="asec" id="as-broadcast">
        <h3 style="font-size:14px;font-weight:800;margin-bottom:14px">📢 Tangazo kwa Wote</h3>
        <div class="form-group">
          <label>Ujumbe wa Tangazo</label>
          <textarea id="bcastMsg" rows="5" style="width:100%;padding:12px;background:rgba(0,0,0,.3);border:1px solid var(--border2);border-radius:12px;color:var(--text);font-size:13.5px;font-family:'DM Sans',sans-serif;outline:none;resize:vertical;transition:border-color .2s" placeholder="Andika tangazo lako hapa... litaenda kwa vyumba vyote!" onfocus="this.style.borderColor='var(--gold)'" onblur="this.style.borderColor='var(--border2)'"></textarea>
        </div>
        <button class="btn btn-gold" onclick="doBroadcast()">📢 Tuma Tangazo kwa Wote</button>
      </div>

      <!-- SETTINGS -->
      <div class="asec" id="as-settings">
        <h3 style="font-size:14px;font-weight:800;margin-bottom:16px">🛠️ Mipangilio ya App</h3>
        <div style="display:flex;flex-direction:column;gap:10px">
          <div style="background:var(--glass);border:1px solid var(--border2);border-radius:13px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between">
            <div><div style="font-weight:700;font-size:13.5px">Futa Data Zote</div><div style="font-size:11.5px;color:var(--muted);margin-top:2px">Futa ujumbe wote wa vyumba (watumiaji wataendelea)</div></div>
            <button class="btn btn-danger btn-sm" onclick="clearAllMsgs()">🗑️ Futa</button>
          </div>
          <div style="background:var(--glass);border:1px solid var(--border2);border-radius:13px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between">
            <div><div style="font-weight:700;font-size:13.5px">Export Data</div><div style="font-size:11.5px;color:var(--muted);margin-top:2px">Pakua nakala ya data yote (JSON)</div></div>
            <button class="btn btn-primary btn-sm" onclick="exportData()">⬇️ Export</button>
          </div>
          <div style="background:var(--glass);border:1px solid rgba(248,113,113,.2);border-radius:13px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between">
            <div><div style="font-weight:700;font-size:13.5px;color:var(--red)">Reset Kamili</div><div style="font-size:11.5px;color:var(--muted);margin-top:2px">Futa kila kitu – hifadhi ya awali</div></div>
            <button class="btn btn-danger btn-sm" onclick="fullReset()">⚠️ Reset</button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

